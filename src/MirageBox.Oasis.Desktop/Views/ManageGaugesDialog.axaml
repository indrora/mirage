<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MirageBox.Oasis.Desktop.ViewModels"
        xmlns:views="using:MirageBox.Oasis.Desktop.Views"
        xmlns:gauges="using:MirageBox.TinyGauges"
        x:Class="MirageBox.Oasis.Desktop.Views.ManageGaugesDialog"
        x:DataType="vm:ManageGaugesViewModel"
        x:CompileBindings="False"
        xmlns:icx="clr-namespace:FluentIcons.Avalonia.Markup;assembly=FluentIcons.Avalonia"
        Width="600" Height="500">
    <DockPanel Margin="12">
        
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="{icx:FluentIcon Dismiss}"
                    Classes="accent" Click="OnDone" />
            <TextBlock Text="Manage Gauges" FontWeight="SemiBold" FontSize="16"
                       VerticalAlignment="Center" />
        </DockPanel>
        

        <!-- Gauge list -->
        <DockPanel DockPanel.Dock="Left" MinWidth="200">
            <StackPanel
                HorizontalAlignment="Right" FlowDirection="LeftToRight"
                DockPanel.Dock="Bottom" Orientation="Horizontal">
                <Button Content="{icx:FluentIcon Icon=GaugeAdd}" Padding="10,4" Command="{Binding AddCommand}" />
                <Button Content="{icx:FluentIcon Delete}" Padding="10,4" Command="{Binding RemoveCommand}" />

            </StackPanel>
            <ListBox ItemsSource="{Binding Names}"
                     SelectedItem="{Binding SelectedName}"
                     Background="Transparent" />
        </DockPanel>

        <!-- Gauge editor -->
        <Border DockPanel.Dock="Right" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="6" Padding="14">
            <ScrollViewer>
            <StackPanel Spacing="10" IsVisible="{Binding HasSelection}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding SelectedName}" FontWeight="SemiBold" FontSize="15"
                    HorizontalAlignment="Stretch"/>
                    <Button Content="{icx:FluentIcon Edit}"
                        IsEnabled="{Binding HasSelection}"
                        Click="OnRenameGauge"

                        />
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock Text="Data source" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <AutoCompleteBox ItemsSource="{Binding DataSourceNames}"
                                     Text="{Binding Source, Mode=TwoWay}"
                                     FilterMode="ContainsOrdinal" />
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock Text="Sensor path" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <AutoCompleteBox ItemsSource="{Binding SensorSuggestions}"
                                     Text="{Binding Sensor, Mode=TwoWay}"
                                     FilterMode="ContainsOrdinal"
                                     PlaceholderText="e.g. time, value, elapsed..." />
                    <TextBlock IsVisible="{Binding ShowSensorElevationHint}"
                               Text="🛡 Needs administrator — value may be empty"
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock Text="Renderer" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ComboBox ItemsSource="{Binding RendererOptions}"
                              SelectedItem="{Binding SelectedRenderer}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:RendererOptionViewModel">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                    <Border IsVisible="{Binding IsFromSource}"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="5,1" VerticalAlignment="Center">
                                        <TextBlock Text="from sensor" FontSize="10"
                                                   Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Dynamic renderer parameters -->
                <ItemsControl ItemsSource="{Binding RendererParams}"
                              IsVisible="{Binding HasRendererParams}">
                    <ItemsControl.ItemTemplate>
                        <views:RendererParamTemplateSelector>
                            <views:RendererParamTemplateSelector.Templates>

                                <DataTemplate x:Key="{x:Static gauges:RendererParamKind.Numeric}"
                                              x:DataType="vm:RendererParamViewModel">
                                    <StackPanel Spacing="3" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="↺"
                                                    ToolTip.Tip="Reset to default"
                                                    Padding="6,4" Margin="4,0,0,0"
                                                    IsVisible="{Binding HasDefault}"
                                                    Click="OnResetRendererParam" Tag="{Binding}" />
                                            <TextBox Text="{Binding Value}"
                                                     PlaceholderText="{Binding Placeholder}" />
                                        </DockPanel>
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate x:Key="{x:Static gauges:RendererParamKind.Text}"
                                              x:DataType="vm:RendererParamViewModel">
                                    <StackPanel Spacing="3" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="↺"
                                                    ToolTip.Tip="Reset to default"
                                                    Padding="6,4" Margin="4,0,0,0"
                                                    IsVisible="{Binding HasDefault}"
                                                    Click="OnResetRendererParam" Tag="{Binding}" />
                                            <TextBox Text="{Binding Value}"
                                                     PlaceholderText="{Binding Placeholder}" />
                                        </DockPanel>
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate x:Key="{x:Static gauges:RendererParamKind.Boolean}"
                                              x:DataType="vm:RendererParamViewModel">
                                    <StackPanel Spacing="3" Margin="0,0,0,6">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding BoolValue}" />
                                    </StackPanel>
                                </DataTemplate>

                                <DataTemplate x:Key="{x:Static gauges:RendererParamKind.Bitmap}"
                                              x:DataType="vm:RendererParamViewModel">
                                    <StackPanel Spacing="3" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding Label}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Browse..."
                                                    Padding="8,4" Margin="4,0,0,0"
                                                    Click="OnBrowseRendererParam"
                                                    Tag="{Binding}" />
                                            <TextBox Text="{Binding Value}"
                                                     PlaceholderText="Path to image file" />
                                        </DockPanel>
                                    </StackPanel>
                                </DataTemplate>

                            </views:RendererParamTemplateSelector.Templates>
                        </views:RendererParamTemplateSelector>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Spacing="3">
                    <TextBlock Text="Label" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding Label}" />
                </StackPanel>

                <StackPanel Spacing="3">
                    <Grid ColumnDefinitions="*,8,*">
                        <StackPanel Grid.Column="0" Spacing="3">
                            <TextBlock Text="Min" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <NumericUpDown Value="{Binding Min}" FormatString="F0" Increment="1" PlaceholderText="auto" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="3">
                            <TextBlock Text="Max" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <NumericUpDown Value="{Binding Max}" FormatString="F0" Increment="1" PlaceholderText="auto" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Leave blank to use the sensor's observed range."
                               FontSize="10" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <StackPanel Spacing="3">
                    <TextBlock Text="Theme override" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding Theme}" PlaceholderText="(use default)" />
                </StackPanel>
            </StackPanel>
            </ScrollViewer>
        </Border>

    </DockPanel>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MirageBox.Oasis.Desktop.ViewModels"
        xmlns:views="using:MirageBox.Oasis.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icx="clr-namespace:FluentIcons.Avalonia.Markup;assembly=FluentIcons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="MirageBox.Oasis.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Title="Oasis — MirageBox Control Surface Manager"
        Width="1100" Height="700" MinWidth="900" MinHeight="550" xmlns:dialogs="using:AvaloniaDialogs.Views">
  

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Border.slot">
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="140" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}" />
        </Style>
        <Style Selector="Border.slot.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark2}" />
        </Style>
        <Style Selector="Border.slot.pinned">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}"/>
        </Style>
        <Style Selector="Border.slot.pinned.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorDark3}" />
            <Setter Property="Background" Value="{DynamicResource SystemAccentColorDark1}" />
        </Style>
        <Style Selector="Border.slot.empty">
            <Setter Property="Opacity" Value="0.55" />
        </Style>

        <Style Selector="Border.inputrow">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        </Style>
        <Style Selector="Border.inputrow.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentButtonBackground}" />
        </Style>

        <Style Selector="TextBlock.section-header">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeLarge}" />
        </Style>
        <Style Selector="TextBlock.field-label">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeSmall}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Scene tabs: plain text with an underline when selected -->
        <Style Selector="ListBox.scene-tabs ListBoxItem">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </Window.Styles>

    <dialogs:ReactiveDialogHost CloseOnClickAway="True" Identifier="MainHost">
    <DockPanel>
        <!-- ═══════════ Header bar ═══════════ -->
        
        <CommandBar DockPanel.Dock="Top">
            <CommandBar.Content>
            <StackPanel FlowDirection="LeftToRight" Orientation="Horizontal">
                <ComboBox MinWidth="240" Background="Transparent" BorderThickness="0"
                          ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:DeviceViewModel">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                    <Run Text="{Binding Buttons}" /><Run Text=" buttons, " />
                                    <Run Text="{Binding Tactile}" /><Run Text=" tactiles, " />
                                    <Run Text="{Binding Encoders}" /><Run Text=" encoders" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <CommandBarSeparator />
                <TabStrip
                    ItemsSource="{Binding DeviceScenes}"
                    SelectedItem="{Binding SelectedScene}"
                    >
                    <TabStrip.DataTemplates>
                        <DataTemplate x:DataType="vm:SceneViewModel">
                            <TabStripItem Content="{Binding Name}" />
                        </DataTemplate>
                    </TabStrip.DataTemplates>
                </TabStrip>
            </StackPanel>
            </CommandBar.Content>
            <CommandBar.PrimaryCommands>
                <CommandBarButton 
                    Label="Scenes"
                    Icon="{icx:FluentIcon Icon=Group }">
                    <CommandBarButton.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Add" Icon="{icx:FluentIcon AddSquare}"
                                      
                                      Command="{Binding AddSceneCommand}"/>
                            <MenuItem
                                Header="Delete" Icon="{icx:FluentIcon SquareEraser}" Command="{Binding RemoveSceneCommand}" />
                                <MenuItem 
                                    Icon="{icx:FluentIcon Icon=CopySelect}"
                                    Header="Duplicate"  Command="{Binding DupeSceneCommand}" />
                                <MenuItem 
                                    Icon="{icx:FluentIcon Icon=Rename}" 
                                    Header="Rename"  Command="{Binding RenameSceneCommand}" />
                        </MenuFlyout>
                    </CommandBarButton.Flyout>
                </CommandBarButton>
                <CommandBarSeparator />
                <CommandBarButton Label="Save" Icon="{icx:FluentIcon Icon=Save}" />
            </CommandBar.PrimaryCommands>
            <CommandBar.SecondaryCommands>
                <CommandBarButton Command="{Binding RevertConfigCommand}"
                                  Icon="{icx:FluentIcon ArrowUndo}" Label="Revert to saved" />
                <CommandBarSeparator />
                <CommandBarButton Click="OnExportConfig"
                                  Icon="{icx:FluentIcon ArrowExport}" Label="Export Configuration" />
                <CommandBarButton Click="OnImportConfig"  
                                  Icon="{icx:FluentIcon ArrowImport}" Label="Import Configuration" />
                <CommandBarButton  Click="OnResetConfig"
                                   Icon="{icx:FluentIcon ArrowReset}" Label="Reset to defaults" />
                <CommandBarSeparator />
                <CommandBarButton Click="OnManageGauges" 
                                  Icon="{icx:FluentIcon Gauge}" Label="Gauges" />
                <CommandBarButton Click="OnManageDataSources"
                                  Icon="{icx:FluentIcon GlobeSync}" Label="Sources" />
                <CommandBarToggleButton Icon="{icx:FluentIcon Live}" Label="Live preview" IsChecked="{Binding LivePreviews}"/>
                <CommandBarSeparator />
                <CommandBarButton  Command="{Binding AddDeviceCommand}"
                                   Icon="{icx:FluentIcon AddSquare}" Label="Add Simulator" />
                <CommandBarButton Command="{Binding RemoveDeviceCommand}"
                                  Icon="{icx:FluentIcon SquareEraser}" Label="Remove simulator" />
            </CommandBar.SecondaryCommands>
        </CommandBar>
        
        <!-- ═══════════ Status strip ═══════════ -->
        <Border DockPanel.Dock="Bottom" Padding="12,4">
            <TextBlock Text="{Binding StatusText}" FontSize="11"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </Border>

        <!-- ═══════════ Body ═══════════ -->
        <Grid ColumnDefinitions="*,Auto,300">

            <!-- Buttons / Switches / Encoders -->
            <Border Grid.Column="0" Margin="12,0,0,8"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14"
                    IsVisible="{Binding HasSelectedDevice}">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <TextBlock Text="Buttons" Classes="section-header" />
                        <ItemsControl ItemsSource="{Binding DisplaySlots}" x:Name="DisplaySlotsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ButtonSlotViewModel">
                                    <Border Classes="slot"
                                            Classes.selected="{Binding IsSelected}"
                                            Classes.pinned="{Binding IsPinned}"
                                            Classes.empty="{Binding IsEmpty}"
                                            Tapped="OnSlotTapped"
                                            PointerPressed="OnSlotPointerPressed"
                                            DragDrop.AllowDrop="True">
                                        <StackPanel VerticalAlignment="Center" Spacing="4">
                                            <Border Width="80" Height="80" CornerRadius="4"
                                                    HorizontalAlignment="Center"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                <Image Source="{Binding Preview}" Stretch="Uniform" />
                                            </Border>
                                            <TextBlock Text="{Binding ContentLabel}" FontSize="12"
                                                       FontWeight="SemiBold" HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="95" />
                                            <TextBlock Text="{Binding PreviewSourceLine}" FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="95" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Switches" Classes="section-header" />
                        <ItemsControl ItemsSource="{Binding TactileSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ButtonSlotViewModel">
                                    <Border Classes="inputrow"
                                            Classes.selected="{Binding IsSelected}"
                                            Tapped="OnSlotTapped" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <!-- keycap-press glyph (placeholder, theme-aware) -->
                                            <Canvas Width="28" Height="28">
                                                <Ellipse Canvas.Left="3" Canvas.Top="6" Width="22" Height="22"
                                                         Stroke="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                                                         StrokeThickness="2" />
                                                <Ellipse Canvas.Left="7" Canvas.Top="10" Width="14" Height="14"
                                                         Fill="{DynamicResource SystemControlBackgroundBaseMediumBrush}" />
                                            </Canvas>
                                            <StackPanel VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding HeaderLabel}" FontSize="10"
                                                           Foreground="{DynamicResource ButtonForegroundThemeBrush}" />
                                                <TextBlock Text="{Binding ContentLabel}" FontSize="14" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Encoders" Classes="section-header" />
                        <ItemsControl ItemsSource="{Binding EncoderSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ButtonSlotViewModel">
                                    <Border Classes="inputrow"
                                            Classes.selected="{Binding IsSelected}"
                                            Tapped="OnSlotTapped" HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <!-- rotary knob glyph (placeholder, theme-aware) -->
                                            <Canvas Width="28" Height="28">
                                                <Ellipse Canvas.Left="3" Canvas.Top="3" Width="22" Height="22"
                                                         Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                                                         StrokeThickness="2" />
                                                <Line StartPoint="14,5" EndPoint="14,12"
                                                      Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                                                      StrokeThickness="2" />
                                            </Canvas>
                                            <StackPanel VerticalAlignment="Center" Spacing="1">
                                                <TextBlock Text="{Binding HeaderLabel}" FontSize="10"
                                                           Foreground="{DynamicResource ButtonForegroundThemeBrush}" />
                                                <TextBlock Text="{Binding ContentLabel}" FontSize="14" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" ResizeBehavior="PreviousAndNext" />

            <!-- ═══════════ Properties sidebar ═══════════ -->
            <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    Padding="12" Margin="0,0,12,8" CornerRadius="6">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Select a button to edit"
                                   IsVisible="{Binding !HasSelectedSlot}"
                                   Foreground="{DynamicResource TextFillColorDisabledBrush}" FontStyle="Italic" />

                        <StackPanel Spacing="10" IsVisible="{Binding HasSelectedSlot}">
                            <TextBlock Text="{Binding SelectedSlot.Title, FallbackValue=''}"
                                       FontWeight="SemiBold" FontSize="17" />

                            <!-- Gauge card = the gauge selector -->
                            <StackPanel Spacing="3" IsVisible="{Binding SelectedSlot.HasDisplay, FallbackValue=False}">
                                <ComboBox ItemsSource="{Binding GaugeNames}"
                                          SelectedItem="{Binding SelectedSlot.GaugeName}"
                                          HorizontalAlignment="Stretch" MinHeight="48"
                                          PlaceholderText="(no gauge — click to choose)" />
                                <TextBlock Text="{Binding SelectedSlot.PreviewSourceLine}" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                            </StackPanel>

                            <CheckBox Content="Pinned across scenes"
                                      IsChecked="{Binding SelectedSlot.IsPinned}"
                                      IsVisible="{Binding SelectedSlot.HasDisplay, FallbackValue=False}" />

                            <Separator Margin="0,2" />
                            <TextBlock Text="Actions" Classes="section-header" />

                            <views:ActionEditor DataContext="{Binding SelectedSlot.Press}" />
                            <views:ActionEditor DataContext="{Binding SelectedSlot.DoublePress}"
                                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedSlot.HasMultiPress, FallbackValue=False}" />
                            <views:ActionEditor DataContext="{Binding SelectedSlot.Hold}"
                                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SelectedSlot.HasMultiPress, FallbackValue=False}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
        </Grid>
        

    </DockPanel>
        </dialogs:ReactiveDialogHost >
</Window>

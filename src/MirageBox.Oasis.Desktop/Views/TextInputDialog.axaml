<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:MirageBox.Oasis.Desktop.Views"
             x:CompileBindings="True"
             x:DataType="views:TextInputDialog"
             x:Class="MirageBox.Oasis.Desktop.Views.TextInputDialog"
             Width="320">
    <StackPanel Margin="8" Spacing="10">
        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontWeight="SemiBold" />
        <TextBox Name="InputBox" Text="{Binding Text}" KeyDown="OnInputKeyDown" />
        <TextBlock Text="{Binding ErrorText}"
                   IsVisible="{Binding HasError}"
                   TextWrapping="Wrap" FontSize="12"
                   Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
        <Grid ColumnDefinitions="* *">
            <Button Grid.Column="0" Name="NegativeButton"
                    Content="{Binding NegativeText}"
                    Margin="4" HorizontalAlignment="Stretch"
                    Click="NegativeButtonClicked" />
            <Button Grid.Column="1" Name="PositiveButton"
                    Content="{Binding PositiveText}"
                    Margin="4" HorizontalAlignment="Stretch"
                    Classes="accent"
                    Click="PositiveButtonClicked" />
        </Grid>
    </StackPanel>
</UserControl>

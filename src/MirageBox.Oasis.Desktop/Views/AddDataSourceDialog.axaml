<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MirageBox.Oasis.Desktop.Views.AddDataSourceDialog"
        Title="Add Data Source"
        Width="420" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <StackPanel Margin="20" Spacing="14">
        <TextBlock Text="Add Data Source" FontWeight="SemiBold" FontSize="16" />

        <StackPanel Spacing="4">
            <TextBlock Text="Name" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBox x:Name="NameBox" PlaceholderText="e.g. myTimer, hwMonitor..." />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Plugin" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <ComboBox x:Name="PluginCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="OnPluginSelectionChanged" />
        </StackPanel>

        <TextBlock x:Name="ElevationWarning" IsVisible="False"
                   Text="⚠ This source needs administrator rights — most of its sensors will be unavailable."
                   TextWrapping="Wrap" FontSize="11"
                   Foreground="{DynamicResource SystemFillColorCautionBrush}" />

        <StackPanel Spacing="4" x:Name="CustomPluginPanel" IsVisible="False">
            <TextBlock Text="Plugin path / assembly" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <TextBox x:Name="CustomPluginBox"
                     PlaceholderText="e.g. MirageBox.DataSource.LHM" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                    Margin="0,8,0,0">
            <Button Content="Cancel" Click="OnCancel" Padding="16,6" />
            <Button Content="Add" Click="OnAdd" Padding="16,6"
                    Classes="accent" />
        </StackPanel>
    </StackPanel>
</Window>
